# Server
# SERVER_PORT is the external entry port for local run and Docker Compose.
SERVER_PORT=11949

# Auth
AUTH_ENABLED=true
# AUTH_LOCAL_PUBLIC_KEY_FILE=configs/local-public-key.pem
# AUTH_JWKS_URI=
# AUTH_ISSUER=

# Chat
# Set a resource ticket secret to enable /api/resource ticket validation.
# Leave it unset to allow resource access without ticket validation.
# CHAT_RESOURCE_TICKET_SECRET=replace-with-your-resource-ticket-secret
# CHAT_RESOURCE_TICKET_TTL_SECONDS=86400

# Budget
# 单次 run 总耗时上限：一条用户消息触发的 agent 执行，从开始到最终回答结束。
AGENT_DEFAULT_BUDGET_TIMEOUT=3600
# 模型流式 idle 超时：首个响应 chunk 或任意两个 chunk 之间超过该秒数无响应则报错。
AGENT_DEFAULT_BUDGET_MODEL_TIMEOUT=30
# 单次后端工具调用硬上限：bash/file/external 等工具不能超过该秒数。
AGENT_DEFAULT_BUDGET_TOOL_TIMEOUT=600

# Container Hub
CONTAINER_HUB_BASE_URL=http://127.0.0.1:11960
# CONTAINER_HUB_DEFAULT_ENVIRONMENT_ID=

# Stream & Debug
# STREAM_INCLUDE_TOOL_PAYLOAD_EVENTS=false
# Optional LLM console log categories. Default is request,usage.
# Uncomment to override with only the categories you need: request, body, raw, parsed, usage, hitl, prompt, system, media, trace, all, none.
# DEBUG_LLM_CONSOLE=request,usage,raw,parsed
# Writes LLM chat traces to ./runtime/chats/<chatId>/.llm-records/<runId>_001.json.
# DEBUG_LLM_CHAT_RECORD=true

# Runtime directories
# RUNTIME_DIR controls where the app reads and writes runtime data.
# Unset directory overrides naturally resolve under RUNTIME_DIR.
RUNTIME_DIR=./runtime
# REGISTRIES_DIR=./runtime/registries
# CHATS_DIR=./runtime/chats
# MEMORY_DIR=./runtime/memory
# PAN_DIR=./runtime/pan

# Gateway channels
# Gateway connections are configured in configs/channels.yml.
# See configs/channels.example.yml for examples.

# Additional config files live under ./configs.
