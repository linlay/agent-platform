# Server
# HOST_PORT is the external entry port used by local run and container port mapping.
# SERVER_PORT is the internal listen port used by the app process itself.
# `make run` usually maps HOST_PORT to SERVER_PORT automatically.
HOST_PORT=11949
# SERVER_PORT=8080

# Auth
AGENT_AUTH_ENABLED=true
# AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=configs/local-public-key.pem
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=

# Chat
# Configure signed chat image access and resource tickets here.
# Leave these commented unless you want to enable them.
# CHAT_IMAGE_TOKEN_SECRET=replace-with-your-chat-image-token-secret
# CHAT_RESOURCE_TICKET_ENABLED=false

# Container Hub
# Container Hub is the external service used for container-based environments.
# AGENT_CONTAINER_HUB_ENABLED turns this integration on or off.
# AGENT_CONTAINER_HUB_AUTH_TOKEN is used for authenticated requests.
# AGENT_CONTAINER_HUB_DEFAULT_ENVIRONMENT_ID sets the default environment to use.
AGENT_CONTAINER_HUB_BASE_URL=http://host.docker.internal:11960
# AGENT_CONTAINER_HUB_ENABLED=true
# AGENT_CONTAINER_HUB_AUTH_TOKEN=
# AGENT_CONTAINER_HUB_DEFAULT_ENVIRONMENT_ID=

# Stream
# Include tool payload events in realtime stream responses.
# AGENT_STREAM_INCLUDE_TOOL_PAYLOAD_EVENTS=true
# Include debug events in realtime stream responses.
# AGENT_STREAM_INCLUDE_DEBUG_EVENTS=true

# Runtime directories
# These paths control where the app reads and writes runtime data.
# REGISTRIES_DIR=./runtime/registries
# OWNER_DIR=./runtime/owner
# AGENTS_DIR=./runtime/agents
# TEAMS_DIR=./runtime/teams
# ROOT_DIR=./runtime/root
# SCHEDULES_DIR=./runtime/schedules
# CHATS_DIR=./runtime/chats
# MEMORY_DIR=./runtime/memory
# SKILLS_MARKET_DIR=./runtime/skills-market
# PAN_DIR=./runtime/pan

# Provider apiKey AES(...)
# Used when a provider registry sets `apiKey: AES(...)`.
# PROVIDER_APIKEY_KEY_PART=

# Memory embedding — 启用后记忆写入时生成向量，query 时使用混合语义检索
# AGENT_MEMORY_EMBEDDING_PROVIDER_KEY 对应 registries/models/providers/*.yml 中的 provider key
# AGENT_MEMORY_EMBEDDING_PROVIDER_KEY=openai
# AGENT_MEMORY_EMBEDDING_MODEL=text-embedding-3-small
# AGENT_MEMORY_EMBEDDING_DIMENSION=1536
# AGENT_MEMORY_EMBEDDING_TIMEOUT_MS=15000

# Memory summarization — 启用后 remember / auto-learn 会把当前内容和历史记忆一起发给大模型做筛选、总结、合并
# AGENT_MEMORY_AUTO_REMEMBER_ENABLED=false
# AGENT_MEMORY_REMEMBER_MODEL_KEY=minimax-m2_7-anthropic
# AGENT_MEMORY_REMEMBER_TIMEOUT_MS=60000
# AGENT_MEMORY_ENABLED=true

# Reverse WebSocket gateway
# When configured, agent-platform will actively connect to this gateway and
# reuse the existing /ws frame protocol in reverse.
#
# GATEWAY_WS_URL 是完整入口，agentKey / channel 等 query 参数由部署侧直接写在 URL 上，
# platform 不再二次拼接。scheme 按网关实际端口是否启用 TLS 选择 ws:// 或 wss://。
#
# GATEWAY_JWT_TOKEN 同时承担 WS 握手 Authorization 与 /api/push、/api/download
# 等 HTTP 旁路请求的 Bearer token；由用户首次企微会话后从网关复制进本文件。
#
# /api/push（artifact 外发）与 /api/download（用户上传文件拉取）已写死在代码中，
# 不再通过 env 配置。
GATEWAY_WS_URL=ws://10.76.32.255:8080/ws/agent?agentKey=zenmi&channel=wecom:xiaozhai
GATEWAY_JWT_TOKEN=
# GATEWAY_BASE_URL=          # 默认从 GATEWAY_WS_URL 的 host 派生，一般无需覆盖
# AGENT_GATEWAY_WS_HANDSHAKE_TIMEOUT_MS=10000
# AGENT_GATEWAY_WS_RECONNECT_MIN_MS=1000
# AGENT_GATEWAY_WS_RECONNECT_MAX_MS=30000

# Additional config files live under ./configs.
