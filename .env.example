# Server
# HOST_PORT is the external entry port used by local run and container port mapping.
# SERVER_PORT is the internal listen port used by the app process itself.
# `make run` usually maps HOST_PORT to SERVER_PORT automatically.
HOST_PORT=11949
# SERVER_PORT=8080

# Auth
AUTH_ENABLED=true
# AUTH_LOCAL_PUBLIC_KEY_FILE=configs/local-public-key.pem
# AUTH_JWKS_URI=
# AUTH_ISSUER=

# Chat
# Set a resource ticket secret to enable /api/resource ticket validation.
# Leave it unset to allow resource access without ticket validation.
# CHAT_RESOURCE_TICKET_SECRET=replace-with-your-resource-ticket-secret
# CHAT_RESOURCE_TICKET_TTL_SECONDS=86400

# Container Hub
CONTAINER_HUB_BASE_URL=http://127.0.0.1:11960
# CONTAINER_HUB_DEFAULT_ENVIRONMENT_ID=

# Host shell
# Leave unset for platform defaults: Windows uses powershell.exe; Unix/macOS use bash.
# AGENT_BASH_SHELL_EXECUTABLE=
# AGENT_BASH_SHELL_ARGS=

# Stream
# STREAM_INCLUDE_TOOL_PAYLOAD_EVENTS=true
# STREAM_INCLUDE_DEBUG_EVENTS=true

# Runtime directories
# These paths control where the app reads and writes runtime data.
# REGISTRIES_DIR=./runtime/registries
# OWNER_DIR=./runtime/owner
# AGENTS_DIR=./runtime/agents
# TEAMS_DIR=./runtime/teams
# ROOT_DIR=./runtime/root
# SCHEDULES_DIR=./runtime/schedules
# CHATS_DIR=./runtime/chats
# MEMORY_DIR=./runtime/memory
# SKILLS_MARKET_DIR=./runtime/skills-market
# PAN_DIR=./runtime/pan

# Provider apiKey AES(...)
# Used when a provider registry sets `apiKey: AES(...)`.
# PROVIDER_APIKEY_KEY_PART=

# Gateway channels
# Gateway connections are configured in configs/channels.yml.
# See configs/channels.example.yml for examples.

# Additional config files live under ./configs.
