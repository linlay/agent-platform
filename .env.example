# Server
# Primary external port knob for both local `make run` and compose.
# Local `make run` maps HOST_PORT into the app listen port.
# Compose maps HOST_PORT to container port 8080.
# Local `make run` also defaults `CGO_ENABLED=0`; direct `go run` does not.
# Advanced, debug, and internal envs are intentionally omitted here.
# See `docs/configuration-reference.md` for the full supported env surface.
HOST_PORT=11949
# Program-mode bundles such as Desktop builtin services read SERVER_PORT directly.
SERVER_PORT=11949
# Optional internal compatibility override.
# `make run` auto-loads .env; direct `go run ./cmd/agent-platform-runner` does not.

# Auth
AGENT_AUTH_ENABLED=true
# Relative paths resolve from the project root.
# A bare filename like `local-public-key.pem` is also treated as `configs/local-public-key.pem` for compatibility.
# AGENT_AUTH_LOCAL_PUBLIC_KEY_FILE=configs/local-public-key.pem
# AGENT_AUTH_JWKS_URI=
# AGENT_AUTH_ISSUER=

# Chat image token / resource ticket
CHAT_IMAGE_TOKEN_SECRET=replace-with-your-chat-image-token-secret
CHAT_RESOURCE_TICKET_ENABLED=true

# Container Hub
AGENT_CONTAINER_HUB_BASE_URL=http://host.docker.internal:11960
# AGENT_CONTAINER_HUB_ENABLED=true
# AGENT_CONTAINER_HUB_AUTH_TOKEN=
# AGENT_CONTAINER_HUB_DEFAULT_ENVIRONMENT_ID=

# WebSocket
# Expose the main product-facing switch here; queue/timeout tuning stays in docs/configuration-reference.md.
# AGENT_WS_ENABLED=true

# SSE response payloads
# Expose the main product-facing SSE payload switch here; heartbeat/render tuning stays in docs/configuration-reference.md.
# AGENT_SSE_INCLUDE_TOOL_PAYLOAD_EVENTS=false

# Global agent defaults
# AGENT_DEFAULT_MAX_TOKENS=4096
# AGENT_DEFAULT_BUDGET_RUN_TIMEOUT_MS=300000
# AGENT_DEFAULT_BUDGET_MODEL_MAX_CALLS=30
# AGENT_DEFAULT_BUDGET_MODEL_TIMEOUT_MS=120000
# AGENT_DEFAULT_BUDGET_MODEL_RETRY_COUNT=0
# AGENT_DEFAULT_BUDGET_TOOL_MAX_CALLS=20
# AGENT_DEFAULT_BUDGET_TOOL_TIMEOUT_MS=120000
# AGENT_DEFAULT_BUDGET_TOOL_RETRY_COUNT=0
# AGENT_DEFAULT_REACT_MAX_STEPS=60
# AGENT_DEFAULT_PLAN_EXECUTE_MAX_STEPS=60
# AGENT_DEFAULT_PLAN_EXECUTE_MAX_WORK_ROUNDS_PER_TASK=6

# Runtime directories for both `make run` and `docker compose`.
# Local runs read these paths directly; Compose uses them as host bind-mount sources.
# Structured startup config remains fixed under ./configs.
# REGISTRIES_DIR=./runtime/registries
# OWNER_DIR=./runtime/owner
# AGENTS_DIR=./runtime/agents
# TEAMS_DIR=./runtime/teams
# ROOT_DIR=./runtime/root
# SCHEDULES_DIR=./runtime/schedules
# CHATS_DIR=./runtime/chats
# MEMORY_DIR=./runtime/memory
# SKILLS_MARKET_DIR=./runtime/skills-market
# PAN_DIR=./runtime/pan

# Provider apiKey AES(...) decrypt support.
# Weak protection only: code part lives in the program, env part comes from .env / environment.
# When provider apiKey uses AES(...), this env var is required at startup.
# PROVIDER_APIKEY_KEY_PART=

# Structured config files live under ./configs:
# - bash.yml
# - container-hub.yml
# - cors.yml
# - local-public-key.pem
